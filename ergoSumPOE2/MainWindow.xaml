<Window x:Class="ergoSumPOE2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ergoSumPOE2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">


    <Window.Resources>
        <!-- Simple Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Arial Rounded MT Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#003F6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    
    <Grid>

            <!-- 
            HOME GRID
            This grid serves as the main landing page  of the application.
            It contains a logo for AI , a welcome message to greet users,
            and a navigation button to proceed to the next section.
            Currently hidden by default.
        -->
            <Grid  Background="AliceBlue" x:Name="home_grid" Visibility="Visible">

                <!-- Logo -->
                <Image 
                Source="/logo.png"
                Width="250"
                Margin="275,17,275,217"
                   />
                <!-- welcome message-->
                <TextBlock
                Text="Welcome to Ergo Sum AI chatbot, click continue button"
                Height="20"
                Width="300"
                TextAlignment="Center"
                Margin="0,30,0,0"
                FontFamily="Arial Rounded MT Bold"
                />

                <!-- button to continue-->
                <Button 
                Height="40"
                Width="300"
                Margin="0,200,0,0"
                Content="Proceed"
                Click="proceed"
                />

            </Grid>

            <!-- 
            USERNAME GRID
            This grid is for prompting the user for username.
            It contains a logo for AI, a textbox for users to enter their name,
            and a submit button to save the username.
            Hidden .
        -->
            <Grid x:Name="username_grid" Visibility="Hidden">


                <!-- Logo -->
                <Image 
                Source="/logo.png" 
                Height="200"
                Width="300"
                Margin="0,0,0,200"
                   />
                <!-- Hint message-->
                <TextBlock
                Text="Enter username"
                Height="20"
                Width="270"
                TextAlignment="Justify"
                Margin="0,30,0,0"
                FontFamily="Arial Rounded MT Bold"
                />

                <!-- Enter/Prompt username-->
                <TextBox
                Height="40"
                Width="270"
                TextAlignment="Center"
                Margin="0,100,0,0"
                FontFamily="Arial Rounded MT Bold"
                x:Name="usernames_input"
                />

                <!-- error message-->
                <TextBlock
         Text="please enter username to continue..."
         Height="20"
         Width="270"
         TextAlignment="Justify"
         Margin="0,180,0,0"
         Foreground="Red"
         FontFamily="Arial Rounded MT Bold"
         />

                <!-- button to submit name-->
                <Button 
        Height="40"
        Width="270"
        Margin="0,250,0,0"
        Content="submit username"
        Click="submit_name"
        />

            </Grid>

            <!-- 
            CHAT GRID
            This grid handles all messaging and conversation-related features of the application.
            It contains a ListView to display chat messages, a textbox for typing questions,
            and a submit button to send the question to the chat.
            Starting in a hidden state.
        -->
            <Grid x:Name="chat_grid" Visibility="Hidden">


                <!-- List view to show messages show messages-->
                <ListView  
                x:Name="chats" 
                Height="300"
                Margin="0,0,0,120"
                />


                <!-- TextBox to prompt questions-->
                <TextBox
                x:Name="question"
                Height="50"
                Width="480"
                Margin="0,300,300,0"
                />

                <!-- button to submit -->
                <Button
                Height="50"
                Width="280"
                Margin="490,300,0,0"
                Content="send "
                Click="send"
                />

            </Grid>



    </Grid>
</Window>
